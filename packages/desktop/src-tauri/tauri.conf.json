{
  "$schema": "https://schema.tauri.app/config/2.json",
  "identifier": "app.marktext.marktext",
  "productName": "marktext",
  "version": "../package.json",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:renderer",
    "beforeDevCommand": "pnpm dev:renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MarkText",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/rg"],
    "category": "Productivity",
    "copyright": "Copyright © MarkText contributors",
    "shortDescription": "A simple and elegant markdown editor.",
    "longDescription": "MarkText is a simple and elegant open-source markdown editor focused on speed and usability.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mmd", "mdown", "mkd", "mkdn", "mdwn", "mdtxt", "mdtext"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzMjNFMTYwOEU5QTdEOUMKUldTY2ZacU9ZT0VqZ3dQTzZVN3lFNmhSYk8wWU5IQ1JKQzRRczBXWUs3d21URUdSdDNDZVNNaEIK",
      "endpoints": [
        "https://github.com/marktext/marktext/releases/latest/download/latest.json"
      ]
    }
  }
}
